{
  "name": "shardm-sap-dmc-pod",
  "displayName": "SHAR-DM SAP Digital Manufacturing POD Plugin Generator",
  "description": "SAP DMC POD Plugin Generator by SHAR-DM — supports POD 1.0, 1.1, 1.1 CLI, 2.0 UI5, and 2.0 React",
  "publisher": "shardm",
  "icon": "images/icon.png",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/shardm/shardm-sap-dmc-pod"
  },
  "engines": { "vscode": "^1.99.3" },
  "categories": ["Programming Languages", "Formatters", "Other"],
  "keywords": ["sap", "dmc", "pod", "plugin", "sapui5", "react", "scaffold", "generator"],
  "main": "./extension.js",
  "activationEvents": [
    "onCommand:SHARD_M.POD_Plugin",
    "onCommand:SHARD_M.zipWorkspace"
  ],
  "contributes": {
    "commands": [
      { "command": "SHARD_M.POD_Plugin", "title": "SHAR-DM: Create SAP DM POD Plugin" },
      { "command": "SHARD_M.zipWorkspace", "title": "SHAR-DM: ZIP Workspace" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "SHARD_M.zipWorkspace", "when": "workspaceFolderCount > 0" }
      ],
      "statusBar/context": [
        { "command": "SHARD_M.zipWorkspace", "when": "workspaceFolderCount > 0" }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "package": "npx vsce package",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.99.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1"
  },
  "dependencies": {
    "archiver": "^7.0.1"
  },
  "license": "MIT"
}
